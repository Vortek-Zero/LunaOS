# Luna — variáveis de ambiente (copie para .env e preencha)

# API
LUNA_API_HOST=0.0.0.0
LUNA_API_PORT=5050
# LUNA_API_KEY=          # gerada automaticamente em .api_key se omitida
LUNA_ADMIN_PASSWORD=      # senha para endpoints admin (obrigatória para /api/admin/*)

# LLM — pelo menos uma key recomendada
MISTRAL_API_KEY=
GEMINI_API_KEY=
# OPENROUTER_API_KEY=    # (sem créditos no momento)
# CHUTES_API_KEY=        # (sem créditos no momento)
# GITHUB_TOKEN=          # GitHub PAT para models.inference.ai.azure.com — DeepSeek V3 / R1
# Naga AI API (naga.ac) — Nemotron, Llama gratuitos
NAGA_API_KEY=
# Best AI API (api.oaibest.com) — DeepSeek, Qwen, Gemini gratuitos
BESTAI_API_KEY=
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OLLAMA_URL=http://localhost:11434

# Pesquisa / STT
TAVILY_API_KEY=

# Spotify
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://localhost:8888/callback

# Home Assistant (opcional)
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# WhatsApp bridge local opcional (sem API Meta — ex: whatsapp-web.js em localhost:3001)
# WHATSAPP_BRIDGE_URL=http://localhost:3001

LUNA_WORKER_URL=http://192.168.1.100:8000
LUNA_WORKER_API_KEY=

# TTS (opcional)
# LUNA_TTS_VOICE=pt-BR-ThalitaMultilingualNeural
# ELEVENLABS_API_KEY=
# AZURE_SPEECH_KEY=
