{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "luna-desktop",
  "version": "0.1.0",
  "identifier": "com.pera.luna-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Luna AI",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "center": true,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGRjE3NEQ1NTFBRkY3NjQKUldSazk2OVIxWFR4cnhROUxWT2dwcEs1dDlrMG5DMzNuMXVvNythMG9tSkt3cTJWYlJNbVRIM28K",
      "endpoints": [
        "https://raw.githubusercontent.com/milogol2822/LunaOS/public-release/luna-desktop/packaging/aur/update.json"
      ],
      "dialog": true
    }
  }
}
